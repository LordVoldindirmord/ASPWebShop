@model WebShop.Domain.ViewModel.CartModel.CartViewModel

@{
    ViewData["Title"] = "Корзина";
}

<div class="cart-container">
    <h1 class="cart-title">Корзина</h1>

    @if (Model.Items == null || !Model.Items.Any())
    {
        <div class="cart-empty">
            <div class="cart-empty-icon">🛒</div>
            <h2>Корзина пуста</h2>
            <p>Добавьте товары из каталога</p>
            <a asp-controller="Product" asp-action="MainMenu" class="btn-catalog">Перейти в каталог</a>
        </div>
    }
    else
    {
        <div class="cart-layout">
            <div class="cart-items">
                @foreach (var item in Model.Items)
                {
                    <div class="cart-item">
                        <div class="cart-item-image">
                            @if (!string.IsNullOrEmpty(item.MainImageUrl))
                            {
                                <img src="@item.MainImageUrl" alt="@item.ProductName" />
                            }
                            else
                            {
                                <div class="no-image">Нет фото</div>
                            }
                        </div>

                        <div class="cart-item-info">
                            <h3 class="cart-item-name">@item.ProductName</h3>
                            <span class="cart-item-category">@item.CategoryName</span>
                            <span class="cart-item-price">@item.Price.ToString("C") / шт.</span>
                        </div>

                        <div class="cart-item-quantity">
                            <form asp-action="UpdateQuantity" method="post">
                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                <div class="quantity-control">
                                    <button type="button" class="qty-btn qty-minus">−</button>
                                    <input type="number" name="quantity" value="@item.Quantity" min="1" max="@item.StockQuantity" class="qty-input" />
                                    <button type="button" class="qty-btn qty-plus">+</button>
                                </div>
                            </form>
                        </div>

                        <div class="cart-item-total">
                            <span class="item-total-price">@item.TotalPrice.ToString("C")</span>
                        </div>

                        <div class="cart-item-remove">
                            <form asp-action="RemoveFromCart" method="post">
                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                <button type="submit" class="btn-remove" title="Удалить">×</button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            <div class="cart-summary">
                <h3>Итого</h3>
                <div class="summary-row">
                    <span>Товаров:</span>
                    <span>@Model.ItemsCount шт.</span>
                </div>
                <div class="summary-row summary-total">
                    <span>Общая сумма:</span>
                    <span>@Model.TotalAmount.ToString("C")</span>
                </div>
                <form asp-controller="Order" asp-action="Checkout" method="post">
                    <button type="submit" class="btn-checkout">Оформить заказ</button>
                </form>
                <a asp-controller="Product" asp-action="MainMenu" class="btn-continue">Продолжить покупки</a>
            </div>
        </div>
    }

    @section Scripts {
        <script>
                document.querySelectorAll('.qty-btn').forEach(btn => {
                    btn.addEventListener('click', function() {
                        const form = this.closest('form');
                        const input = form.querySelector('.qty-input');
                        const max = parseInt(input.max) || 100;
                
                        if (this.classList.contains('qty-plus')) {
                            input.value = Math.min(parseInt(input.value) + 1, max);
                        } else {
                            input.value = Math.max(parseInt(input.value) - 1, 1);
                        }
                
                        input.closest('form').submit();
                    });
                });

                // Отправка формы при ручном вводе количества (Enter или уход с поля)
                document.querySelectorAll('.qty-input').forEach(input => {
                    input.addEventListener('change', function() {
                        this.closest('form').submit();
                    });
                });
        </script>
    }
</div>