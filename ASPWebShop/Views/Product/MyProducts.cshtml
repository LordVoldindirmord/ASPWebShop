@model IEnumerable<WebShop.Domain.ViewModel.ProductModel.ProductViewModel>

@{
    ViewData["Title"] = ViewBag.IsAdmin == true ? "Все товары (Админ)" : "Мои товары";
}

<div class="my-products-container">
    <div class="my-products-header">
        <h1>@ViewData["Title"]</h1>
        <a asp-controller="Product" asp-action="Create" class="btn-add-product">+ Добавить товар</a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="empty-products">
            <div class="empty-icon">📦</div>
            <h2>Товаров пока нет</h2>
            <p>Добавьте свой первый товар</p>
            <a asp-controller="Product" asp-action="Create" class="btn-add-first">+ Добавить товар</a>
        </div>
    }
    else
    {
        <div class="products-table-wrapper">
            <table class="products-table">
                <thead>
                    <tr>
                        <th>Фото</th>
                        <th>Название</th>
                        <th>Категория</th>
                        <th>Цена</th>
                        <th>Остаток</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td class="td-image">
                                @if (!string.IsNullOrEmpty(product.MainImageUrl))
                                {
                                    <img src="@product.MainImageUrl" alt="@product.Name" />
                                }
                                else
                                {
                                    <div class="no-image-small">Нет</div>
                                }
                            </td>
                            <td class="td-name">@product.Name</td>
                            <td>@product.CategoryName</td>
                            <td>@product.Price.ToString("C")</td>
                            <td>
                                <span class="stock @(product.StockQuantity > 0 ? "in-stock" : "out-of-stock")">
                                    @product.StockQuantity шт.
                                </span>
                            </td>
                            <td>
                                <span class="status @(product.IsActive ? "active" : "inactive")">
                                    @(product.IsActive ? "Активен" : "Скрыт")
                                </span>
                            </td>
                            <td class="td-actions">
                                <a asp-action="Edit" asp-route-id="@product.Id" class="btn-action btn-edit">Изменить</a>
                                <form asp-action="ToggleProductStatus" method="post" style="display:inline;">
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <button type="submit" class="btn-action btn-toggle">
                                        @(product.IsActive ? "Скрыть" : "Показать")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>