@model WebShop.Domain.ViewModel.UserModel.LoginViewModel

@{
    ViewData["Title"] = "Вход";
    Layout = "_AuthLayout";
}

<div class="auth-container">
    <h1 class="auth-title">Вход в аккаунт</h1>

    <form asp-action="Login" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="form-group">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" type="email" placeholder="example@mail.ru" />
            <span asp-validation-for="Email" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password">Пароль</label>
            <input asp-for="Password" type="password" placeholder="Введите пароль" />
            <span asp-validation-for="Password" class="field-validation-error"></span>
        </div>

        <div class="form-check">
            <input asp-for="RememberMe" type="checkbox" />
            <label asp-for="RememberMe">Запомнить меня</label>
        </div>

        <button type="submit" class="btn-submit">Войти</button>
    </form>

    <p class="auth-link">
        Нет аккаунта? <a asp-action="Register">Зарегистрироваться</a>
    </p>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}